# ============================================================
# Phase 0 — environment template (operator must populate before
# deploying the security-stabilization branch)
# ============================================================
# Copy to `.env`, fill in real values, never commit secrets.

# ---------- Django ----------
DJANGO_ENV=development
DEBUG=False
SECRET_KEY=change-me-django-secret-key

# ---------- Phase 1 — observability + tenant authority ----------
# JSON log formatter in production; text in dev.
LOG_FORMAT=text
LOG_LEVEL=INFO
# Schema authority enforcement: 1 = raise on cross-tenant kwarg overrides
# (default), 0 = log-only soak mode used briefly during Phase 2 migration.
SCHEMA_AUTHORITY_ENFORCE=1
# Dynamic-object gateway feature flag. Off until Phase 2 wires BL through it.
USE_DYNAMIC_GATEWAY=0

# ---------- Sentry (0.11) ----------
# Get the DSN from https://sentry.io/ → Project Settings → Client Keys
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
GIT_SHA=

# ---------- OAuth token encryption (0.8) ----------
# REQUIRED. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# To rotate keys without downtime, supply OAUTH_TOKEN_ENC_KEYS as a
# comma-separated list (newest first); decryption falls back to older keys.
OAUTH_TOKEN_ENC_KEY=
# OAUTH_TOKEN_ENC_KEYS=newkey,oldkey

# ---------- Voxbay telephony (0.6, 0.9) ----------
# These were previously HARDCODED in source. Rotate with the provider
# before populating here.
VOXBAY_UID=
VOXBAY_PIN=
VOXBAY_EXT=108
VOXBAY_CALLER_ID=
VOXBAY_DESTINATION_NUMBER=
VOXBAY_AGENT_DIAL_NUMBER=
# HMAC secret used to sign Voxbay webhook bodies. Configure on the
# Voxbay side to send `X-Voxbay-Signature: sha256=<hex>` header.
VOXBAY_WEBHOOK_SECRET=
# Set VOXBAY_WEBHOOK_ENFORCE=0 during the rollout to log-only-mode
# (signatures still checked & logged, but request not rejected).
# Default is 1 (enforce).
VOXBAY_WEBHOOK_ENFORCE=1

# ---------- Twilio (existing) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---------- Google / Gmail OAuth (existing) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URL=

# ---------- Outlook OAuth (existing) ----------
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=

# ---------- Database, Redis, etc. (existing) ----------
DATABASE_URL=
REDIS_URL=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
